# .env.example — Shreyas Khandare Automation System
# Copy this file to .env and fill in all values.
# NEVER commit .env to git. It is listed in .gitignore.
# -------------------------------------------------------

# ── Anthropic / Claude API ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Telegram Bot ────────────────────────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# Your personal chat ID (use @userinfobot to get it)
TELEGRAM_CHAT_ID=

# ── Gmail OAuth2 ────────────────────────────────────────────────────────────
# Create credentials at console.cloud.google.com → OAuth2 → Desktop App
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
# Generate once via: python -m shared.gmail_auth (Session 5 sets this up)
GMAIL_REFRESH_TOKEN=

# ── Job Discovery ───────────────────────────────────────────────────────────
# SerpAPI — google jobs search
SERPAPI_API_KEY=
# Apify — LinkedIn scraping (optional, only needed when linkedin_apify.enabled=true)
APIFY_API_TOKEN=

# ── Recruiter Outreach ──────────────────────────────────────────────────────
# Apollo.io — recruiter lookup
APOLLO_API_KEY=
# Hunter.io — email verification
HUNTER_API_KEY=

# ── Google Sheets ───────────────────────────────────────────────────────────
# Path to your service account JSON file (do NOT commit the JSON file itself)
GOOGLE_SHEETS_CREDENTIALS_JSON=/path/to/service-account.json
# Sheet ID from the Google Sheets URL
GOOGLE_SHEET_ID_JOBS=
GOOGLE_SHEET_ID_OUTREACH=

# ── Notion ──────────────────────────────────────────────────────────────────
# Optional — only needed for market_research agent
NOTION_API_KEY=
NOTION_DATABASE_ID_MARKET=

# ── GitHub ──────────────────────────────────────────────────────────────────
# Personal access token with repo + workflow scopes
GITHUB_TOKEN=

# ── Database ────────────────────────────────────────────────────────────────
# Optional override for SQLite path (default: automation.sqlite in repo root)
# DB_PATH=/custom/path/to/automation.sqlite
